---
import { Image } from "astro:assets";
const { tagline, logo } = Astro.props;
const base = import.meta.env.BASE_URL;

const providerCode = `terraform {
  required_providers {
    ignition = {
      source = "apollogeddon/ignition"
    }
  }
}`;
---

<section class="hero-section">
  <div class="glow-container">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
  </div>

  <div class="content">
    {logo && <Image src={logo} alt="Ignition Logo" class="hero-logo" width={120} height={120} />}
    <h1>Ignition <span class="text-gradient">TF Provider</span></h1>
    <p class="tagline">{tagline}</p>

    <div class="actions">
      <a href={`${base}/docs/guides/installation/`} class="btn btn-primary">
        Get Started
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
      </a>
      <a href="https://github.com/apollogeddon/ignition-tfpl" class="btn btn-secondary">
        View on GitHub
      </a>
    </div>

    <div class="quick-install glass">
      <div class="install-header">
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="label">Provider Declaration</span>
      </div>
      <pre><code>{providerCode}</code></pre>
      <button class="copy-btn" id="copy-btn" data-code={providerCode} aria-label="Copy to clipboard">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
      </button>
    </div>
  </div>
</section>

<script>
  const copyBtn = document.querySelector('#copy-btn') as HTMLButtonElement;
  const code = copyBtn?.dataset.code;
  
  copyBtn?.addEventListener('click', async () => {
    if (code) {
      await navigator.clipboard.writeText(code);
      const originalContent = copyBtn.innerHTML;
      copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
      setTimeout(() => {
        copyBtn.innerHTML = originalContent;
      }, 2000);
    }
  });
</script>

<style>
  .hero-section {
    position: relative;
    padding: 8rem 1rem 6rem;
    text-align: center;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .content {
    position: relative;
    z-index: 10;
    max-width: 800px;
  }

  .hero-logo {
    width: 120px;
    height: auto;
    margin-bottom: 2rem;
    filter: drop-shadow(0 0 30px rgba(var(--sl-color-accent-rgb), 0.3));
  }

  h1 {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    font-weight: 800;
  }

  .tagline {
    font-size: clamp(1.125rem, 3vw, 1.5rem);
    color: var(--sl-color-text-muted);
    margin-bottom: 3rem;
    text-wrap: balance;
  }

  .actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 4rem;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.8rem 2rem;
    border-radius: 99px;
    font-weight: 600;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--sl-color-accent);
    color: var(--sl-color-text-invert);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px -6px rgba(var(--sl-color-accent-rgb), 0.5);
  }

  .btn-secondary {
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-hairline);
    color: var(--sl-color-text);
  }

  .btn-secondary:hover {
    background: var(--sl-color-gray-5);
  }

  .quick-install {
    position: relative;
    padding: 1.25rem;
    border-radius: 12px;
    text-align: left;
    max-width: 600px;
    margin: 0 auto;
  }

  .install-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--sl-color-gray-4);
  }

  .label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sl-color-text-muted);
    margin-left: 0.5rem;
  }

  pre {
    margin: 0;
    font-size: 0.9rem;
    overflow-x: auto;
    color: var(--sl-color-text);
  }

  .copy-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    color: var(--sl-color-text-muted);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 6px;
    transition: all 0.2s;
  }

  .copy-btn:hover {
    color: var(--sl-color-text);
    background: var(--sl-color-gray-6);
  }

  /* Glow Effects */
  .glow-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .glow {
    position: absolute;
    width: 40vw;
    height: 40vw;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.15;
  }

  .glow-1 {
    top: -10%;
    left: -10%;
    background: var(--sl-color-accent);
  }

  .glow-2 {
    bottom: 0%;
    right: -10%;
    background: var(--sl-color-accent-secondary);
  }

  :root[data-theme='light'] .glow {
    opacity: 0.05;
  }
</style>