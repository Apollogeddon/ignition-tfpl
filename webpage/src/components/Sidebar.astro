---
import { getCollection } from "astro:content";

const docs = await getCollection("docs");
const base = import.meta.env.BASE_URL;
const pathname = new URL(Astro.request.url).pathname;

// Optimized organization logic: single pass to group and sort
const sections = [
	{ label: "Guides", prefix: "guides/" },
	{ label: "Reference", prefix: "reference/" },
]
	.map((section) => ({
		...section,
		items: docs
			.filter((d) => d.id.startsWith(section.prefix))
			.sort((a, b) => a.data.title.localeCompare(b.data.title)),
	}))
	.filter((section) => section.items.length > 0);

/**
 * Checks if a doc link is currently active
 * Handles trailing slashes and base paths consistently
 */
const isActive = (id: string) => {
	const href = `${base}/docs/${id}/`.replace(/\/+/g, "/");
	const current = pathname.replace(/\/+/g, "/");
	return current === href || current === href.slice(0, -1);
};
---

<nav class="sidebar">
  {sections.map(section => (
    <div class="section">
      <h4 class="section-title">{section.label}</h4>
      <ul class="section-items">
        {section.items.map(item => (
          <li>
            <a 
              href={`${base}/docs/${item.id}/`} 
              class={`sidebar-link ${isActive(item.id) ? 'active' : ''}`}
              aria-current={isActive(item.id) ? 'page' : undefined}
            >
              {item.data.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</nav>

<style>
  .sidebar {
    padding-right: 1rem;
  }

  .section {
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sl-color-text-muted);
    margin-bottom: 1rem;
    padding-left: 1rem;
  }

  .section-items {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-link {
    display: block;
    padding: 0.5rem 1rem;
    font-size: 0.95rem;
    text-decoration: none;
    color: var(--sl-color-text-muted);
    border-radius: 6px;
    transition: all 0.2s;
  }

  .sidebar-link:hover {
    color: var(--sl-color-accent);
    background: var(--sl-color-accent-low);
  }
</style>