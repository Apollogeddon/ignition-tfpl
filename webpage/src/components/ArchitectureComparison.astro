---
const base = import.meta.env.BASE_URL;

const models = [
	{
		name: "Resources",
		tagline: "Manage Configuration",
		description:
			"Declaratively define and manage Ignition resources including projects, connections, and security settings.",
		stats: [
			{ label: "Stateful", value: "Yes" },
			{ label: "Action", value: "CRUD" },
			{ label: "Control", value: "Full" },
		],
		features: ["Drift Detection", "Version Control", "Automated Cleanup"],
		link: `${base}/docs/reference/resources/ignition_project/`,
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
	},
	{
		name: "Data Sources",
		tagline: "Reference Existing",
		description:
			"Fetch configuration from an existing Gateway to use as variables or inputs for other resources.",
		stats: [
			{ label: "Stateful", value: "No" },
			{ label: "Action", value: "Read" },
			{ label: "Control", value: "None" },
		],
		features: ["External Referencing", "Safe Lookup", "Zero Impact"],
		link: `${base}/docs/reference/data-sources/ignition_project/`,
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="10" x2="6" y2="14"/><line x1="18" y1="10" x2="18" y2="14"/></svg>`,
	},
];
---

<section class="comparison-section">
  <div class="header">
    <h2>Understand the <span class="text-gradient">Abstractions</span></h2>
    <p>Choose between managing resources or referencing existing configuration.</p>
  </div>

  <div class="comparison-grid">
    {models.map(model => (
      <div class="model-card glass">
        <div class="model-header">
          <div class="icon-box" set:html={model.icon}></div>
          <div>
            <h3>{model.name}</h3>
            <p class="tag">{model.tagline}</p>
          </div>
        </div>
        
        <p class="desc">{model.description}</p>

        <div class="stats-grid">
          {model.stats.map(stat => (
            <div class="stat-item">
              <span class="stat-label">{stat.label}</span>
              <span class="stat-value">{stat.value}</span>
            </div>
          ))}
        </div>

        <ul class="features-list">
          {model.features.map(feature => (
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              {feature}
            </li>
          ))}
        </ul>

        <a href={model.link} class="btn-more">
          View Sources
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        </a>
      </div>
    ))}
  </div>
</section>

<style>
  .comparison-section {
    padding: 4rem 1rem 8rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .header {
    text-align: center;
    margin-bottom: 4rem;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .header p {
    font-size: 1.25rem;
    color: var(--sl-color-gray-4);
  }

  .comparison-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
  }

  .model-card {
    padding: 2.5rem;
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .model-card:hover {
    transform: scale(1.02);
    border-color: rgba(var(--sl-color-accent-rgb), 0.3);
  }

  .model-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .icon-box {
    width: 64px;
    height: 64px;
    background: rgba(var(--sl-color-accent-rgb), 0.1);
    color: var(--sl-color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
  }

  h3 {
    font-size: 1.75rem;
    font-weight: 800;
    margin: 0;
  }

  .tag {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--sl-color-accent);
    margin: 0.25rem 0 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .desc {
    color: var(--sl-color-gray-3);
    line-height: 1.6;
    margin: 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding: 1.25rem;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--sl-color-gray-5);
    font-weight: 600;
  }

  .stat-value {
    font-weight: 700;
    color: var(--sl-color-text);
  }

  .features-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .features-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--sl-color-text);
    font-size: 0.95rem;
  }

  .features-list li svg {
    color: var(--sl-color-accent);
  }

  .btn-more {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem;
    border-radius: 12px;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-text);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-more:hover {
    background: var(--sl-color-accent);
    color: var(--sl-color-text-invert);
    transform: translateY(-2px);
  }
</style>